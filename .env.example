# ═══════════════════════════════════════════════
# EdgeOne Pages 建站骨架 — 环境变量模板
# ═══════════════════════════════════════════════
# 复制此文件为 .env 并按需填写：
#   cp .env.example .env
#
# 注意：D1 数据库通过 EdgeOne Pages 平台绑定 env.DB，
#       无需手动配置连接字符串。DATABASE_URL 仅为向后兼容。
# ═══════════════════════════════════════════════

# ── JWT 双轨认证 ──
# RS256 主签名（推荐）：私钥用于 Cloud Functions 签发，公钥用于 Edge Functions 验证
# 生成方式：openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#          openssl pkey -in private.pem -pubout -out public.pem
# JWT_PRIVATE_KEY=<将 private.pem 全部内容填入此处>
# JWT_PUBLIC_KEY=<将 public.pem 全部内容填入此处>

# HS256 兼容密钥（30 天过渡窗口，RS256 稳定后可移除）
# JWT_SECRET=<至少 32 位随机字符串>

# ── 微信支付（电商栈必需） ──
# WX_APPID=wx_your_appid
# WX_MCHID=your_merchant_id
# WX_API_KEY=your_api_v3_key
# WX_CERT_PATH=<微信证书路径>

# ── 支付宝（电商栈可选） ──
# ALI_APP_ID=your_alipay_app_id
# ALI_PRIVATE_KEY=<支付宝应用私钥>

# ── 内部通信 ──
# Edge Function 内部网关地址（Cloud Functions 通过此地址调用 Edge KV）
# EDGE_BASE=https://your-project.edgeone.cool

# ── D1 数据库（旧版兼容，实际通过平台绑定 env.DB 注入） ──
# DATABASE_URL=d1:<database-id>

# ── 测试用变量 ──
# BASE_URL=http://localhost:8787
# TOKEN_A=<租户A的JWT>
# TOKEN_B=<租户B的JWT>
# SUPERADMIN_TOKEN=<超级管理员JWT>
# TENANT_A_ID=tenant_a
# TENANT_B_ID=tenant_b
