{
  "name": "website-skeleton-skill",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "EdgeOne Pages 全栈网站骨架 Skill — Phase 4A 多租户隔离完成",
  "workspaces": [
    "packages/shared",
    "packages/payment",
    "packages/admin"
  ],
  "scripts": {
    "build": "node scripts/sync-sharing.js",
    "test": "node tests/integration/phase4a.test.js",
